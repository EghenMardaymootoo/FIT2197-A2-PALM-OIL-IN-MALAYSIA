{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Annotated area-and-line chart showing Malaysia's crude palm oil production from 1970 to 2024, with key policy and industry events highlighted.",
  "title": {
    "text": "Half a century of growth",
    "subtitle": "Malaysian crude palm oil production, 1970\u20132024 (million tonnes)",
    "subtitleFontStyle": "italic",
    "anchor": "start",
    "fontSize": 18,
    "subtitleFontSize": 13,
    "subtitleColor": "#5a5a5a",
    "offset": 12
  },
  "width": "container",
  "height": 380,
  "padding": {"top": 10, "left": 10, "right": 30, "bottom": 10},
  "background": "transparent",
  "layer": [
    {
      "description": "Shaded area beneath the production line",
      "data": {"url": "data/malaysia_palm_oil_production.csv"},
      "transform": [{"calculate": "datum.production_tonnes / 1000000", "as": "production_mt"}],
      "mark": {
        "type": "area",
        "color": "#c2410c",
        "opacity": 0.15,
        "interpolate": "monotone",
        "line": false
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "scale": {"domain": [1970, 2025], "nice": false},
          "axis": {
            "title": null,
            "format": "d",
            "labelFontSize": 11,
            "tickCount": 6,
            "grid": false,
            "domain": false,
            "ticks": false
          }
        },
        "y": {
          "field": "production_mt",
          "type": "quantitative",
          "scale": {"domain": [0, 26]},
          "axis": {
            "title": "Million tonnes",
            "titleFontSize": 11,
            "labelFontSize": 11,
            "grid": true,
            "gridColor": "#e8e2d4",
            "domain": false,
            "ticks": false
          }
        }
      }
    },
    {
      "description": "Main production line",
      "data": {"url": "data/malaysia_palm_oil_production.csv"},
      "transform": [{"calculate": "datum.production_tonnes / 1000000", "as": "production_mt"}],
      "mark": {
        "type": "line",
        "color": "#c2410c",
        "strokeWidth": 2.5,
        "interpolate": "monotone"
      },
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "production_mt", "type": "quantitative"},
        "tooltip": [
          {"field": "year", "type": "quantitative", "title": "Year"},
          {"field": "production_mt", "type": "quantitative", "title": "Production (M tonnes)", "format": ".2f"}
        ]
      }
    },
    {
      "description": "Filled circles at each data point",
      "data": {"url": "data/malaysia_palm_oil_production.csv"},
      "transform": [{"calculate": "datum.production_tonnes / 1000000", "as": "production_mt"}],
      "mark": {
        "type": "circle",
        "color": "#c2410c",
        "size": 30,
        "opacity": 0.8
      },
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "production_mt", "type": "quantitative"}
      }
    },
    {
      "description": "Annotation rules \u2014 vertical dashed lines at key events",
      "data": {
        "values": [
          {"year": 1998},
          {"year": 2018},
          {"year": 2019}
        ]
      },
      "mark": {
        "type": "rule",
        "color": "#5a5a5a",
        "strokeDash": [4, 3],
        "strokeWidth": 1,
        "opacity": 0.8
      },
      "encoding": {
        "x": {"field": "year", "type": "quantitative"}
      }
    },
    {
      "description": "Annotation text labels",
      "data": {
        "values": [
          {"year": 1998, "label_y": 22, "label": "1998: Asian financial crisis"},
          {"year": 2018, "label_y": 8, "label": "2018: RSPO rules tighten"},
          {"year": 2019, "label_y": 5, "label": "2019: Area cap at 6.5M ha"}
        ]
      },
      "mark": {
        "type": "text",
        "align": "right",
        "baseline": "middle",
        "dx": -6,
        "fontSize": 10,
        "color": "#5a5a5a",
        "fontStyle": "italic"
      },
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "label_y", "type": "quantitative"},
        "text": {"field": "label"}
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "font": "Inter, system-ui, sans-serif"
  }
}